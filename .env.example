NODE_ENV=production
LOG_LEVEL=info

WORKSPACE_ROOT=/workspace
MCP_HTTP_PORT=8080
HEALTH_PORT=8081

AUDIT_ENABLED=true
AUDIT_DIR=/workspace/.fms-mcp/audit
AUDIT_ARCHIVE_DIR=/workspace/.fms-mcp/audit-archive

# Authentik / Claude.ai remote MCP OAuth
OAUTH_ENABLED=true
PUBLIC_BASE_URL=https://mcp-proxy.xoka.workers.dev/fms
OAUTH_ISSUER=https://auth.xoka.com/application/o/fms-mcp/
OAUTH_JWKS_URI=https://auth.xoka.com/application/o/fms-mcp/jwks/
OAUTH_AUDIENCE=<client-id-from-authentik>
OAUTH_CLIENT_ID=<client-id-from-authentik>
OAUTH_CLIENT_SECRET=<client-secret-from-authentik>
CORS_EXTRA_ORIGINS=
